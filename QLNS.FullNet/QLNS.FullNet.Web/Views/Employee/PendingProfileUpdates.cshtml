@model IEnumerable<QLNS.FullNet.Data.Entities.ProfileUpdateRequest>
@{
    ViewData["Title"] = "Duyệt yêu cầu cập nhật hồ sơ";
}

<div class="dashboard">
    <div class="dashboard-header">
        <h1 class="dashboard-title">Phê duyệt cập nhật hồ sơ</h1>
        <p class="dashboard-subtitle">Các yêu cầu thay đổi thông tin từ nhân viên</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mt-3">@TempData["SuccessMessage"]</div>
    }

    <div class="chart-card mt-3">
        <table class="table data-table align-middle">
            <thead class="table-light">
                <tr>
                    <th>Thời gian gửi</th>
                    <th>Nhân viên</th>
                    <th>SĐT mới</th>
                    <th>Ngày sinh mới</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Không có yêu cầu nào đang chờ duyệt.</td></tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="fw-bold text-primary">@item.Employee?.FullName</td>
                        <td>@item.NewPhoneNumber</td>
                        <td>@(item.NewDateOfBirth?.ToString("dd/MM/yyyy"))</td>
                        <td class="text-center">
                            <form asp-action="ApproveProfileUpdate" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" name="isApproved" value="true" class="btn btn-sm btn-success me-1">Duyệt</button>
                                <button type="submit" name="isApproved" value="false" class="btn btn-sm btn-danger">Từ chối</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>