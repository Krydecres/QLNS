@model QLNS.FullNet.Data.Entities.Employee
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="dashboard">
    <div class="dashboard-header">
        <div>
            <h1 class="dashboard-title">Hồ sơ cá nhân</h1>
            <p class="dashboard-subtitle">Xem thông tin chi tiết tài khoản của bạn</p>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-8">
            <div class="chart-card">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                    <div class="d-flex align-items-center">
                        <a href="#" data-bs-toggle="modal" data-bs-target="#avatarModal">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img src="@Model.AvatarUrl" alt="Avatar" class="rounded-circle me-3 shadow-sm" style="width: 80px; height: 80px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 80px; height: 80px; font-size: 32px;">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                            }
                        </a>
                        <div>
                            <h3 class="mb-1 text-primary">@Model.FullName</h3>
                            <span class="badge bg-info text-dark shadow-sm">@(Model.Position?.Name ?? "Chưa có chức vụ")</span>
                        </div>
                    </div>
                    <a asp-action="EditMyProfile" asp-controller="Employee" class="btn btn-outline-primary shadow-sm">
                        <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
                    </a>
                </div>

                <table class="table table-borderless">
                    <tbody>
                        <tr>
                            <th width="30%" class="text-muted"><i class="bi bi-person-vcard me-2"></i>Mã nhân viên:</th>
                            <td class="fw-bold">NV-@Model.Id</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-envelope me-2"></i>Email liên hệ:</th>
                            <td class="fw-bold">@Model.Email</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-telephone me-2"></i>Số điện thoại:</th>
                            <td class="fw-bold">@(Model.PhoneNumber ?? "Chưa cập nhật")</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-calendar2-date me-2"></i>Ngày sinh:</th>
                            <td class="fw-bold">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</td>
                        </tr>
                        <tr>
                            <th class="text-muted"><i class="bi bi-diagram-3 me-2"></i>Phòng ban:</th>
                            <td>
                                <span class="badge-status badge-leave">@(Model.Department?.Name ?? "Chưa xếp phòng")</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Avatar Upload Modal -->
<div class="modal fade" id="avatarModal" tabindex="-1" aria-labelledby="avatarModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="avatarModalLabel">Cập nhật ảnh đại diện</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UploadAvatar" asp-controller="Employee" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="text-center mb-3">
                        <img id="avatarPreview" src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "/images/default-avatar.png" : Model.AvatarUrl)" alt="Xem trước ảnh" class="rounded-circle" style="width: 150px; height: 150px; object-fit: cover;" />
                    </div>
                    <div class="mb-3">
                        <label for="avatarFile" class="form-label">Chọn ảnh mới (dưới 1MB):</label>
                        <input class="form-control" type="file" id="avatarFile" name="avatarFile" accept="image/png, image/jpeg" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-upload me-1"></i> Tải lên</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const avatarFileInput = document.getElementById('avatarFile');
            const avatarPreview = document.getElementById('avatarPreview');

            avatarFileInput.onchange = function (evt) {
                const [file] = this.files;
                if (file) {
                    avatarPreview.src = URL.createObjectURL(file);
                }
            };
        });
    </script>
}