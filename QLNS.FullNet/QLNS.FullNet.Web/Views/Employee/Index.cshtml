@using QLNS.FullNet.Data.Entities
@model IEnumerable<Employee>

@{
    ViewData["Title"] = "Danh sách nhân viên";
}

<div class="dashboard">
    <div class="dashboard-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="dashboard-title">Danh sách nhân viên</h1>
            <p class="dashboard-subtitle">Quản lý thông tin chi tiết của nhân viên trong công ty</p>
        </div>
        <div class="dashboard-actions">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Thêm nhân viên
            </a>
        </div>
    </div>

    <div class="chart-card mt-3">
        <table class="data-table table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th width="8%">Mã NV</th>
                    <th width="8%" class="text-center">Ảnh</th>
                    <th>Họ và tên</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Phòng ban</th>
                    <th>Chức vụ</th>
                    <th width="20%" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            Chưa có dữ liệu nhân viên.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>NV-@item.Id</td>

                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.AvatarUrl))
                                {
                                    <img src="@item.AvatarUrl"
                                         alt="Avatar"
                                         class="rounded-circle shadow-sm"
                                         style="width: 45px; height: 45px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-secondary text-white rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm"
                                         style="width: 45px; height: 45px; font-size: 20px;">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                }
                            </td>

                            <td class="fw-bold text-primary">@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.PhoneNumber</td>

                            <td>
                                <span class="badge-status badge-leave">
                                    @(item.Department?.Name ?? "Chưa xếp phòng")
                                </span>
                            </td>

                            <td>
                                <span class="badge bg-info text-dark">
                                    @(item.Position?.Name ?? "Chưa có")
                                </span>
                            </td>

                            <td class="text-center">
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary me-1"
                                   title="Chỉnh sửa">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      style="display:inline;"
                                      onsubmit="return confirm('Bạn có chắc chắn muốn xóa nhân viên @item.FullName?');">
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger"
                                            title="Xóa">
                                        <i class="bi bi-trash"></i> Xóa
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>