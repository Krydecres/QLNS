@model List<QLNS.FullNet.Data.Entities.Salary>

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-0">Dữ liệu bảng lương</h1>
            <p class="text-muted small mb-0">Tổng hợp lương nhân viên theo từng kỳ</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <!-- Xuất Excel -->
            <a asp-action="ExportExcel" asp-route-month="@ViewBag.SelectedMonth" asp-route-year="@ViewBag.SelectedYear" 
               class="btn btn-outline-success">
                <i class="bi bi-file-earmark-excel me-1"></i> Xuất Excel
            </a>
            <!-- Gửi Email hàng loạt -->
            <form asp-action="SendAllPayslips" method="post" class="d-inline"
                  onsubmit="return confirm('Bạn có chắc chắn muốn GỬI EMAIL PHIẾU LƯƠNG cho TẤT CẢ nhân viên trong tháng này?')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="month" value="@ViewBag.SelectedMonth" />
                <input type="hidden" name="year" value="@ViewBag.SelectedYear" />
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-envelope-paper me-1"></i> Gửi tất cả
                </button>
            </form>
            <!-- Xóa toàn bộ -->
            <form asp-action="DeleteAll" method="post" class="d-inline"
                  onsubmit="return confirm('Xóa TOÀN BỘ dữ liệu lương của tất cả các tháng? Hành động này không thể hoàn tác!')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-trash3 me-1"></i> Xóa tất cả
                </button>
            </form>
            <a asp-controller="SalarySettings" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-sliders me-1"></i> Cài đặt lương
            </a>
        </div>
    </div>

    <!-- Thông báo -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Bộ lọc & Tính lương -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body py-3">
            <form method="get" asp-controller="Salaries" asp-action="Index" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label mb-1 small fw-semibold">Tháng</label>
                    <input type="number" name="month" class="form-control form-control-sm" style="width:80px"
                           value="@ViewBag.SelectedMonth" min="1" max="12" required />
                </div>
                <div class="col-auto">
                    <label class="form-label mb-1 small fw-semibold">Năm</label>
                    <input type="number" name="year" class="form-control form-control-sm" style="width:100px"
                           value="@ViewBag.SelectedYear" min="2000" required />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm btn-secondary">
                        <i class="bi bi-search me-1"></i>Xem
                    </button>
                </div>
                <div class="col-auto ms-auto">
                    <button type="submit" asp-controller="Salaries" asp-action="Seed" class="btn btn-primary">
                        <i class="bi bi-calculator me-1"></i>
                        Tính lương tháng @ViewBag.SelectedMonth/@ViewBag.SelectedYear
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <!-- Summary cards -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body p-3">
                        <div class="text-muted small mb-1">Số nhân viên</div>
                        <div class="fs-3 fw-bold text-primary">@Model.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body p-3">
                        <div class="text-muted small mb-1">Tổng lương ngày công</div>
                        <div class="fs-6 fw-bold text-dark">@Model.Sum(x => x.BaseSalary).ToString("N0") đ</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body p-3">
                        <div class="text-muted small mb-1">Tổng phụ cấp</div>
                        <div class="fs-6 fw-bold text-success">+@Model.Sum(x => x.Allowance).ToString("N0") đ</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body p-3">
                        <div class="text-muted small mb-1">Tổng chi trả</div>
                        <div class="fs-6 fw-bold text-success">@Model.Sum(x => x.TotalSalary).ToString("N0") đ</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bảng chi tiết -->
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:90px">Kỳ lương</th>
                                <th>Nhân viên</th>
                                <th class="text-end">
                                    Lương ngày công
                                    <span class="text-muted fw-normal" style="font-size:0.75rem;">(đ)</span>
                                </th>
                                <th class="text-end">
                                    Phụ cấp
                                    <span class="text-muted fw-normal" style="font-size:0.75rem;">(đ)</span>
                                </th>
                                <th class="text-end">
                                    Khấu trừ
                                    <span class="text-muted fw-normal" style="font-size:0.75rem;">(đ)</span>
                                </th>
                                <th class="text-end">
                                    Tổng lương
                                    <span class="text-muted fw-normal" style="font-size:0.75rem;">(đ)</span>
                                </th>
                                <th class="text-center" style="width:90px">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        @string.Format("T{0}/{1}", item.Month, item.Year)
                                    </span>
                                </td>
                                <td class="fw-semibold">
                                    @(item.Employee?.FullName ?? $"NV-{item.EmployeeId}")
                                </td>
                                <td class="text-end text-dark">
                                    @item.BaseSalary.ToString("N0")
                                </td>
                                <td class="text-end text-success fw-semibold">
                                    @if (item.Allowance > 0)
                                    {
                                        <span>+@item.Allowance.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-end text-danger">
                                    @if (item.Deduction > 0)
                                    {
                                        <span>-@item.Deduction.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <span class="fw-bold text-success">
                                        @item.TotalSalary.ToString("N0") đ
                                    </span>
                                </td>
                                <td class="text-center text-nowrap">
                                    <form asp-action="SendPayslip" asp-route-id="@item.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Gửi email phiếu lương cho nhân viên này?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-info me-1" title="Gửi Email">
                                            <i class="bi bi-envelope"></i>
                                        </button>
                                    </form>
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary me-1" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Xóa bản lương này?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                        <tfoot class="table-light fw-semibold">
                            <tr>
                                <td colspan="2" class="text-end text-muted small">Tổng cộng:</td>
                                <td class="text-end">@Model.Sum(x => x.BaseSalary).ToString("N0")</td>
                                <td class="text-end text-success">+@Model.Sum(x => x.Allowance).ToString("N0")</td>
                                <td class="text-end text-danger">
                                    @if (Model.Sum(x => x.Deduction) > 0)
                                    {
                                        <span>-@Model.Sum(x => x.Deduction).ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-end text-success fw-bold">
                                    @Model.Sum(x => x.TotalSalary).ToString("N0") đ
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-5 text-center">
                <i class="bi bi-table text-muted" style="font-size: 3rem;"></i>
                <h5 class="mt-3 text-muted">Chưa có dữ liệu lương cho kỳ @ViewBag.SelectedMonth/@ViewBag.SelectedYear</h5>
                <p class="text-muted mb-0">Bấm <strong>Tính lương</strong> để hệ thống tự động tổng hợp từ chấm công và nghỉ phép.</p>
            </div>
        </div>
    }
</div>