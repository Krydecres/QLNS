@model QLNS.FullNet.Web.Models.AdminDashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard Quản trị";
    var now = DateTime.Now;

    var salaryLabelsJson  = JsonSerializer.Serialize(Model.SalaryChartLabels);
    var salaryDataJson    = JsonSerializer.Serialize(Model.SalaryChartData);
    var attLabelsJson     = JsonSerializer.Serialize(Model.AttendanceLabels);
    var attPresentJson    = JsonSerializer.Serialize(Model.AttendancePresentData);
    var attLeaveJson      = JsonSerializer.Serialize(Model.AttendanceLeaveData);
    var attAbsentJson     = JsonSerializer.Serialize(Model.AttendanceAbsentData);
    var deptLabelsJson    = JsonSerializer.Serialize(Model.DeptLabels);
    var deptDataJson      = JsonSerializer.Serialize(Model.DeptData);
}

<div class="dashboard">

    <!-- Header -->
    <div class="dashboard-header">
        <div>
            <h1 class="dashboard-title">Tổng quan hệ thống</h1>
            <p class="dashboard-subtitle">
                Quản lý nhân sự và chấm công — @now.ToString("dddd, dd/MM/yyyy")
            </p>
        </div>
        <div class="dashboard-actions d-flex gap-2 flex-wrap">
            <span class="badge-shift">
                <i class="bi bi-sun"></i> @now.ToString("HH:mm") — Đang hoạt động
            </span>
            @if (Model.PendingLeaveRequests > 0)
            {
                <a asp-controller="LeaveRequest" asp-action="Approval" class="badge-shift text-decoration-none" style="background:#fef9c3;border-color:#fde68a;color:#92400e;">
                    <i class="bi bi-bell-fill"></i> @Model.PendingLeaveRequests đơn chờ duyệt
                </a>
            }
        </div>
    </div>

    <!-- Stat Cards Row 1: Nhân sự & Chấm công -->
    <div class="stat-grid mt-3">
        <a asp-controller="Employee" asp-action="Index" class="stat-card text-decoration-none" style="color:inherit;">
            <div class="stat-icon icon-blue"><i class="bi bi-people"></i></div>
            <div class="stat-label">Tổng nhân viên</div>
            <div class="stat-value">@Model.TotalEmployees</div>
            <div class="stat-note">@Model.TotalDepartments phòng ban · @Model.TotalPositions chức vụ</div>
        </a>

        <a asp-controller="Timekeeping" asp-action="Index" class="stat-card text-decoration-none" style="color:inherit;">
            <div class="stat-icon icon-green"><i class="bi bi-patch-check"></i></div>
            <div class="stat-label">Có mặt hôm nay</div>
            <div class="stat-value">@Model.PresentToday</div>
            <div class="stat-note text-success">@Model.PresentRate% có mặt</div>
        </a>

        <a asp-controller="Timekeeping" asp-action="Index" class="stat-card stat-card--warn text-decoration-none" style="color:inherit;">
            <div class="stat-icon icon-yellow"><i class="bi bi-person-x"></i></div>
            <div class="stat-label">Chưa chấm công</div>
            <div class="stat-value">@Model.NotCheckedToday</div>
            <div class="stat-note text-warning">
                @Model.AbsentToday vắng có phép
            </div>
        </a>

        <a asp-controller="LeaveRequest" asp-action="Approval" class="stat-card @(Model.PendingLeaveRequests > 0 ? "stat-card--warn" : "") text-decoration-none" style="color:inherit;">
            <div class="stat-icon icon-teal"><i class="bi bi-calendar-check"></i></div>
            <div class="stat-label">Đơn nghỉ phép chờ duyệt</div>
            <div class="stat-value">@Model.PendingLeaveRequests</div>
            <div class="stat-note @(Model.PendingLeaveRequests > 0 ? "text-warning" : "text-muted")">
                @(Model.PendingLeaveRequests > 0 ? "Cần xử lý" : "Đã xử lý hết")
            </div>
        </a>

        <a asp-controller="Salaries" asp-action="Index" class="stat-card text-decoration-none" style="color:inherit;">
            <div class="stat-icon icon-green"><i class="bi bi-cash-coin"></i></div>
            <div class="stat-label">Tổng lương tháng @now.Month</div>
            <div class="stat-value" style="font-size:1.15rem">
                @(Model.TotalSalaryThisMonth > 0 ? Model.TotalSalaryThisMonth.ToString("N0") + " đ" : "Chưa tính")
            </div>
            <div class="stat-note @(Model.SalaryUp ? "text-success" : "text-danger")">
                @if (Model.TotalSalaryLastMonth > 0)
                {
                    <i class="bi bi-arrow-@(Model.SalaryUp ? "up" : "down")"></i>
                    <text>@((Model.SalaryUp ? "+" : "") + Model.SalaryDiff.ToString("N0")) đ</text>
                    <span class="text-muted">vs T@(now.Month == 1 ? 12 : now.Month - 1)</span>
                }
                else
                {
                    <span class="text-muted">@Model.SalaryCalculatedCount / @Model.TotalEmployees NV đã tính</span>
                }
            </div>
        </a>

        <a asp-controller="Employee" asp-action="Index" class="stat-card @(Model.PendingProfileUpdates > 0 ? "stat-card--warn" : "") text-decoration-none" style="color:inherit;">
            <div class="stat-icon icon-purple"><i class="bi bi-person-lines-fill"></i></div>
            <div class="stat-label">Cập nhật hồ sơ chờ duyệt</div>
            <div class="stat-value">@Model.PendingProfileUpdates</div>
            <div class="stat-note @(Model.PendingProfileUpdates > 0 ? "text-warning" : "text-muted")">
                @(Model.PendingProfileUpdates > 0 ? "Cần xem xét" : "Không có yêu cầu")
            </div>
        </a>
    </div>

    <!-- Charts Row 1 -->
    <div class="chart-grid mt-4">
        <div class="chart-card chart-card--wide">
            <h2 class="chart-title">Tình hình chấm công 7 ngày gần nhất</h2>
            <p class="chart-sub">Số lượt có mặt, vắng có phép và vắng không phép theo ngày.</p>
            <canvas id="attendanceChart" height="110"></canvas>
        </div>
        <div class="chart-card">
            <h2 class="chart-title">Nhân sự theo phòng ban</h2>
            <p class="chart-sub">Tỷ trọng headcount hiện tại.</p>
            <canvas id="deptChart" height="200"></canvas>
        </div>
    </div>

    <!-- Charts Row 2 -->
    <div class="chart-grid">
        <div class="chart-card chart-card--wide">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h2 class="chart-title">Tổng lương chi trả theo tháng (6 tháng gần nhất)</h2>
                    <p class="chart-sub">Đơn vị: triệu đồng — dữ liệu thực từ bảng lương.</p>
                </div>
                <a asp-controller="Salaries" asp-action="Index" class="btn btn-sm btn-outline-success">
                    <i class="bi bi-table me-1"></i>Xem bảng lương
                </a>
            </div>
            <canvas id="salaryChart" height="110"></canvas>
        </div>
        <div class="chart-card">
            <h2 class="chart-title">Số liệu nhanh tháng @now.Month/@now.Year</h2>
            <p class="chart-sub">Tổng hợp các chỉ số quan trọng.</p>
            <div class="list-group list-group-flush mt-2">
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center border-0 py-2">
                    <span class="text-muted"><i class="bi bi-people me-2 text-primary"></i>Tổng nhân viên</span>
                    <strong>@Model.TotalEmployees</strong>
                </div>
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center border-0 py-2">
                    <span class="text-muted"><i class="bi bi-cash-stack me-2 text-success"></i>Đã tính lương</span>
                    <strong>@Model.SalaryCalculatedCount / @Model.TotalEmployees</strong>
                </div>
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center border-0 py-2">
                    <span class="text-muted"><i class="bi bi-check2-circle me-2 text-success"></i>Có mặt hôm nay</span>
                    <strong class="text-success">@Model.PresentToday (@Model.PresentRate%)</strong>
                </div>
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center border-0 py-2">
                    <span class="text-muted"><i class="bi bi-x-circle me-2 text-danger"></i>Chưa chấm công</span>
                    <strong class="text-danger">@Model.NotCheckedToday</strong>
                </div>
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center border-0 py-2">
                    <span class="text-muted"><i class="bi bi-hourglass me-2 text-warning"></i>Đơn nghỉ chờ duyệt</span>
                    <strong class="text-warning">@Model.PendingLeaveRequests</strong>
                </div>
                <div class="list-group-item px-0 d-flex justify-content-between align-items-center border-0 py-2">
                    <span class="text-muted"><i class="bi bi-person-lines-fill me-2 text-info"></i>Hồ sơ chờ duyệt</span>
                    <strong class="text-info">@Model.PendingProfileUpdates</strong>
                </div>
            </div>
        </div>
    </div>

    <!-- Table: Nhân viên chưa chấm công hôm nay -->
    <div class="chart-card mt-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div>
                <h2 class="chart-title mb-0">Nhân viên chưa chấm công hôm nay</h2>
                <p class="chart-sub mb-0">Danh sách cần xác nhận trạng thái — @now.ToString("dd/MM/yyyy")</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Timekeeping" asp-action="ManualEntry" class="btn btn-sm btn-outline-success">
                    <i class="bi bi-pencil-square me-1"></i>Nhập thủ công
                </a>
                <a asp-controller="Timekeeping" asp-action="Index" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-clock-history me-1"></i>Dữ liệu chấm công
                </a>
            </div>
        </div>
        @if (Model.AbsentEmployees.Any())
        {
            <table class="data-table mt-2">
                <thead>
                    <tr>
                        <th>Mã NV</th>
                        <th>Họ tên</th>
                        <th>Phòng ban</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model.AbsentEmployees)
                    {
                        <tr>
                            <td><span class="text-muted">NV-@emp.Id</span></td>
                            <td class="fw-semibold">@emp.FullName</td>
                            <td>@(emp.DepartmentName ?? "—")</td>
                            <td>
                                @if (emp.Status == "Nghỉ có phép")
                                {
                                    <span class="badge-status badge-leave">Nghỉ có phép</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-absent">Chưa chấm công</span>
                                }
                            </td>
                            <td>
                                <form asp-controller="Timekeeping" asp-action="CheckIn" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="employeeId" value="@emp.Id" />
                                    <button type="submit" class="btn btn-outline-success py-0 px-2" style="font-size:11px;"
                                            title="Chấm công có mặt cho @emp.FullName">
                                        <i class="bi bi-box-arrow-in-right me-1"></i>Check-in
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 2.5rem;"></i>
                <p class="mt-2 mb-0 fw-semibold text-success">Tất cả nhân viên đã chấm công hôm nay!</p>
            </div>
        }
    </div>

</div>

@section Scripts {
<script>
const g = { dark:'#1D6A4A', mid:'#2D9F6F', light:'#6CC49A', pale:'#B8E4CF' };

// Chấm công 7 ngày — dữ liệu thực
const attLabels  = @Html.Raw(attLabelsJson);
const attPresent = @Html.Raw(attPresentJson);
const attLeave   = @Html.Raw(attLeaveJson);
const attAbsent  = @Html.Raw(attAbsentJson);

new Chart(document.getElementById('attendanceChart'), {
    type: 'bar',
    data: {
        labels: attLabels,
        datasets: [
            { label: 'Có mặt',           data: attPresent, backgroundColor: g.mid,    borderRadius: 4 },
            { label: 'Vắng có phép',     data: attLeave,   backgroundColor: g.light,  borderRadius: 4 },
            { label: 'Vắng không phép',  data: attAbsent,  backgroundColor: '#f0a04b',borderRadius: 4 }
        ]
    },
    options: {
        plugins: { legend: { position: 'top' } },
        scales: { x: { stacked: true }, y: { stacked: true, beginAtZero: true, ticks: { precision: 0 } } }
    }
});

// Phòng ban donut — dữ liệu thực
const deptLabels = @Html.Raw(deptLabelsJson);
const deptData   = @Html.Raw(deptDataJson);
const deptColors = [g.dark, g.mid, g.light, g.pale, '#a78bfa', '#60a5fa', '#f472b6'];

new Chart(document.getElementById('deptChart'), {
    type: 'doughnut',
    data: {
        labels: deptLabels.length ? deptLabels : ['Chưa có dữ liệu'],
        datasets: [{
            data: deptData.length ? deptData : [1],
            backgroundColor: deptColors,
            borderWidth: 2, borderColor: '#fff'
        }]
    },
    options: {
        cutout: '60%',
        plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } } }
    }
});

// Lương 6 tháng — dữ liệu thực
const salaryLabels = @Html.Raw(salaryLabelsJson);
const salaryData   = @Html.Raw(salaryDataJson);

new Chart(document.getElementById('salaryChart'), {
    type: 'line',
    data: {
        labels: salaryLabels,
        datasets: [{
            label: 'Tổng lương (triệu đồng)',
            data: salaryData,
            borderColor: g.dark,
            backgroundColor: g.pale + '55',
            pointBackgroundColor: g.dark,
            pointRadius: 5,
            tension: 0.4,
            fill: true
        }]
    },
    options: {
        plugins: { legend: { position: 'top' } },
        scales: { y: { beginAtZero: false, ticks: { callback: v => v + 'tr' } } }
    }
});
</script>
}