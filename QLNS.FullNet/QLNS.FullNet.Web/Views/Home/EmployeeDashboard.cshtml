@model QLNS.FullNet.Web.Models.EmployeeDashboardViewModel
@using QLNS.FullNet.Data.Entities
@{
    ViewData["Title"] = "Dashboard Cá nhân";
    var now = DateTime.Now;
    var employee = Model.Employee;
    var today = now.Date;

    // So sánh lương tháng này vs tháng trước
    decimal salaryDiff = 0;
    bool salaryUp = false;
    if (Model.CurrentSalary != null && Model.PreviousSalary != null && Model.PreviousSalary.TotalSalary > 0)
    {
        salaryDiff = Model.CurrentSalary.TotalSalary - Model.PreviousSalary.TotalSalary;
        salaryUp = salaryDiff >= 0;
    }

    // Trạng thái check-in/check-out hôm nay
    bool checkedInToday   = Model.TodayTimekeeping != null;
    bool checkedOutToday  = Model.TodayTimekeeping?.CheckOutTime != null;
}

<div class="dashboard">
    <!-- Header -->
    <div class="dashboard-header">
        <div>
            <h1 class="dashboard-title">Xin chào, @(employee?.FullName ?? User.Identity?.Name ?? "Nhân viên")!</h1>
            <p class="dashboard-subtitle">
                @(employee?.Department?.Name != null ? employee.Department.Name + " — " : "")Tổng quan thông tin cá nhân và công việc của bạn — @now.ToString("dddd, dd/MM/yyyy")
            </p>
        </div>
        <div class="dashboard-actions d-flex gap-2 align-items-center flex-wrap">
            <span class="badge-shift">
                <i class="bi bi-briefcase"></i> @(employee?.Position?.Name ?? "Đang làm việc")
            </span>
            @if (!checkedInToday)
            {
                <!-- Chưa check-in -->
                <form asp-controller="Timekeeping" asp-action="CheckIn" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-sm px-3">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Check-in
                    </button>
                </form>
            }
            else if (!checkedOutToday)
            {
                <!-- Đã check-in, chưa check-out -->
                <span class="badge-status badge-present">
                    <i class="bi bi-check-circle me-1"></i>
                    Check-in: @(Model.TodayTimekeeping!.CheckInTime.HasValue ? Model.TodayTimekeeping.CheckInTime.Value.ToString(@"hh\:mm") : "--:--")
                </span>
                <form asp-controller="Timekeeping" asp-action="CheckOut" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning btn-sm px-3 text-dark">
                        <i class="bi bi-box-arrow-right me-1"></i>Check-out
                    </button>
                </form>
            }
            else
            {
                <!-- Đã check-out -->
                <span class="badge-status badge-present">
                    <i class="bi bi-check2-all me-1"></i>
                    Hoàn thành @(Model.TodayTimekeeping!.CheckInTime.HasValue ? Model.TodayTimekeeping.CheckInTime.Value.ToString(@"hh\:mm") : "") → @(Model.TodayTimekeeping.CheckOutTime.HasValue ? Model.TodayTimekeeping.CheckOutTime.Value.ToString(@"hh\:mm") : "")
                </span>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stat Cards -->
    <div class="stat-grid mt-3">
        <!-- Ngày công -->
        <div class="stat-card">
            <div class="stat-icon icon-blue"><i class="bi bi-calendar-check"></i></div>
            <div class="stat-label">Tổng ngày công</div>
            <div class="stat-value">@(Model.DaysWorked + Model.ApprovedLeaveDays)</div>
            <div class="stat-note text-muted" style="font-size: 0.85rem;">
                (@Model.DaysWorked làm + @Model.ApprovedLeaveDays phép)
            </div>
        </div>

        <!-- Lương tháng này -->
        <div class="stat-card @(Model.CurrentSalary != null ? "" : "stat-card--warn")">
            <div class="stat-icon icon-green"><i class="bi bi-cash-coin"></i></div>
            <div class="stat-label">Lương tháng @now.Month/@now.Year</div>
            @if (Model.CurrentSalary != null)
            {
                <div class="stat-value" style="font-size: 1.3rem;">@Model.CurrentSalary.TotalSalary.ToString("N0") đ</div>
                @if (Model.PreviousSalary != null)
                {
                    <div class="stat-note @(salaryUp ? "text-success" : "text-danger")">
                        <i class="bi bi-arrow-@(salaryUp ? "up" : "down")"></i>
                        @(salaryUp ? "+" : "")@salaryDiff.ToString("N0") đ so với T@(now.Month == 1 ? 12 : now.Month - 1)
                    </div>
                }
                else
                {
                    <div class="stat-note text-muted">Chưa có dữ liệu tháng trước</div>
                }
            }
            else
            {
                <div class="stat-value">Chờ chốt</div>
                <div class="stat-note text-muted">Chưa có dữ liệu tháng này</div>
            }
        </div>

        <!-- Lương ước tính đến hôm nay -->
        <div class="stat-card">
            <div class="stat-icon icon-teal"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="stat-label">Ước tính đến hôm nay</div>
            @if (Model.EstimatedSalaryToDate > 0)
            {
                <div class="stat-value" style="font-size: 1.2rem;">@Model.EstimatedSalaryToDate.ToString("N0") đ</div>
                <div class="stat-note text-muted">Dựa trên @(Model.DaysWorked + Model.ApprovedLeaveDays) ngày công</div>
            }
            else
            {
                <div class="stat-value">—</div>
                <div class="stat-note text-muted">Chưa có dữ liệu ngày công</div>
            }
        </div>

        <!-- Lương tháng trước -->
        <div class="stat-card">
            <div class="stat-icon icon-yellow"><i class="bi bi-clock-history"></i></div>
            <div class="stat-label">Lương tháng trước</div>
            @if (Model.PreviousSalary != null)
            {
                <div class="stat-value" style="font-size: 1.2rem;">@Model.PreviousSalary.TotalSalary.ToString("N0") đ</div>
                <div class="stat-note text-muted">Tháng @Model.PreviousSalary.Month/@Model.PreviousSalary.Year</div>
            }
            else
            {
                <div class="stat-value">—</div>
                <div class="stat-note text-muted">Chưa có dữ liệu</div>
            }
        </div>
    </div>

    <!-- Main Content Row -->
    <div class="row mt-4">
        <!-- Chấm công gần đây -->
        <div class="col-md-6 mb-4">
            <div class="chart-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="chart-title mb-0">Chấm công gần đây</h2>
                    <a asp-controller="Timekeeping" asp-action="MyAttendance" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
                </div>
                <table class="data-table table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Ngày</th>
                            <th>Ca làm</th>
                            <th>Giờ vào</th>
                            <th>Giờ ra</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentTimekeepings.Any())
                        {
                            foreach (var item in Model.RecentTimekeepings)
                            {
                                <tr>
                                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                                    <td><span class="text-muted small">@(item.Shift?.Name ?? "Ca tự do")</span></td>
                                    <td>
                                        @if (item.CheckInTime.HasValue)
                                        {
                                            <span class="text-success fw-semibold">@item.CheckInTime.Value.ToString(@"hh\:mm")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.CheckOutTime.HasValue)
                                        {
                                            <span class="text-primary fw-semibold">@item.CheckOutTime.Value.ToString(@"hh\:mm")</span>
                                        }
                                        else if (item.Date.Date == today && item.CheckInTime.HasValue)
                                        {
                                            <span class="badge bg-warning text-dark">Đang làm</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Status == "Có mặt")
                                        {
                                            <span class="badge bg-success">Có mặt</span>
                                        }
                                        else if (item.Status == "Vắng có phép")
                                        {
                                            <span class="badge bg-info text-dark">Vắng có phép</span>
                                        }
                                        else if (item.Status == "Vắng không phép")
                                        {
                                            <span class="badge bg-danger">Vắng không phép</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@(item.Status ?? "—")</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu chấm công.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Chi tiết lương tháng này -->
        <div class="col-md-6 mb-4">
            <div class="chart-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="chart-title mb-0">Chi tiết lương tháng @now.Month/@now.Year</h2>
                    <a asp-controller="Salaries" asp-action="Index" class="btn btn-sm btn-outline-success">Xem bảng lương</a>
                </div>
                @if (Model.CurrentSalary != null)
                {
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th class="text-muted"><i class="bi bi-currency-dollar me-2"></i>Lương cơ bản</th>
                                <td class="fw-bold text-end">@Model.CurrentSalary.BaseSalary.ToString("N0") đ</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-plus-circle me-2 text-success"></i>Phụ cấp</th>
                                <td class="fw-bold text-success text-end">+ @Model.CurrentSalary.Allowance.ToString("N0") đ</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-dash-circle me-2 text-danger"></i>Khấu trừ</th>
                                <td class="fw-bold text-danger text-end">- @Model.CurrentSalary.Deduction.ToString("N0") đ</td>
                            </tr>
                            <tr class="border-top">
                                <th><i class="bi bi-wallet2 me-2 text-primary"></i>Tổng lương nhận</th>
                                <td class="text-end">
                                    <span class="badge bg-success fs-6">@Model.CurrentSalary.TotalSalary.ToString("N0") đ</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-receipt" style="font-size: 3rem; opacity: 0.3;"></i>
                        <p class="mt-2">Chưa có dữ liệu lương tháng @now.Month/@now.Year</p>
                        <small>Vui lòng liên hệ Admin để tính lương.</small>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Lịch sử lương + Đơn từ -->
    <div class="row">
        <!-- Lịch sử 6 tháng -->
        <div class="col-md-6 mb-4">
            <div class="chart-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="chart-title mb-0">Lịch sử lương</h2>
                    <span class="text-muted small">6 tháng gần nhất</span>
                </div>
                @if (Model.SalaryHistory.Any())
                {
                    <table class="data-table table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Kỳ lương</th>
                                <th class="text-end">Lương cơ bản</th>
                                <th class="text-end">Tổng nhận</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.SalaryHistory)
                            {
                                var isCurrentMonth = (s.Month == now.Month && s.Year == now.Year);
                                <tr class="@(isCurrentMonth ? "table-success" : "")">
                                    <td>
                                        Tháng @s.Month/@s.Year
                                        @if (isCurrentMonth)
                                        {
                                            <span class="badge bg-success ms-1">Hiện tại</span>
                                        }
                                    </td>
                                    <td class="text-end">@s.BaseSalary.ToString("N0") đ</td>
                                    <td class="text-end fw-bold">@s.TotalSalary.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-bar-chart-line" style="font-size: 3rem; opacity: 0.3;"></i>
                        <p class="mt-2">Chưa có lịch sử lương.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Đơn từ & Yêu cầu -->
        <div class="col-md-6 mb-4">
            <div class="chart-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="chart-title mb-0">Đơn từ & Yêu cầu</h2>
                    <a asp-controller="LeaveRequest" asp-action="Create" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-plus-circle me-1"></i>Tạo đơn nghỉ
                    </a>
                </div>

                @{
                    var hasAny = Model.LeaveRequests.Any() || Model.ProfileRequests.Any();
                }

                @if (hasAny)
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var leave in Model.LeaveRequests)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <div>
                                    <div class="fw-semibold">
                                        <i class="bi bi-calendar-x text-danger me-2"></i>
                                        Nghỉ phép: @leave.StartDate.ToString("dd/MM") – @leave.EndDate.ToString("dd/MM/yyyy")
                                    </div>
                                    <small class="text-muted">@leave.Reason</small>
                                </div>
                                @if (leave.Status == LeaveRequestStatus.Pending)
                                {
                                    <span class="badge bg-warning text-dark rounded-pill ms-2 flex-shrink-0">Chờ duyệt</span>
                                }
                                else if (leave.Status == LeaveRequestStatus.Approved)
                                {
                                    <span class="badge bg-success rounded-pill ms-2 flex-shrink-0">Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger rounded-pill ms-2 flex-shrink-0">Từ chối</span>
                                }
                            </li>
                        }
                        @foreach (var req in Model.ProfileRequests)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2">
                                <div>
                                    <div class="fw-semibold">
                                        <i class="bi bi-person-lines-fill text-info me-2"></i>Cập nhật hồ sơ
                                    </div>
                                    <small class="text-muted">Gửi lúc: @req.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                                @if (req.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark rounded-pill ms-2 flex-shrink-0">Đang chờ duyệt</span>
                                }
                                else if (req.Status == "Approved")
                                {
                                    <span class="badge bg-success rounded-pill ms-2 flex-shrink-0">Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger rounded-pill ms-2 flex-shrink-0">Từ chối</span>
                                }
                            </li>
                        }
                    </ul>
                    <div class="mt-3 text-center">
                        <a asp-controller="LeaveRequest" asp-action="MyLeaves" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-list-ul me-1"></i>Xem tất cả đơn nghỉ phép
                        </a>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox" style="font-size: 2rem; opacity: 0.3;"></i>
                        <p class="mt-2">Chưa có đơn từ hay yêu cầu nào.</p>
                        <a asp-controller="LeaveRequest" asp-action="Create" class="btn btn-sm btn-outline-primary mt-1">
                            <i class="bi bi-plus-circle me-1"></i>Tạo đơn nghỉ phép
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>