@model IEnumerable<QLNS.FullNet.Data.Entities.LeaveRequest>
@{
    ViewData["Title"] = "Duyệt đơn nghỉ phép";
}

<div class="mb-4">
    <h2 class="mb-0">Duyệt đơn nghỉ phép</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nhân viên</th>
                        <th>Từ ngày</th>
                        <th>Đến ngày</th>
                        <th>Lý do</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Employee?.FullName</td>
                            <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.Reason</td>
                            <td>
                                @if (item.Status == QLNS.FullNet.Data.Entities.LeaveRequestStatus.Pending)
                                {
                                    <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                }
                                else if (item.Status == QLNS.FullNet.Data.Entities.LeaveRequestStatus.Approved)
                                {
                                    <span class="badge bg-success">Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Từ chối</span>
                                }
                            </td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.Status == QLNS.FullNet.Data.Entities.LeaveRequestStatus.Pending)
                                {
                                    <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#approveModal-@item.Id">Duyệt</button>
                                    <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal-@item.Id">Từ chối</button>

                                    <!-- Approve Modal -->
                                    <div class="modal fade" id="approveModal-@item.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <form asp-action="ProcessRequest" method="post">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="status" value="@QLNS.FullNet.Data.Entities.LeaveRequestStatus.Approved" />
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Xác nhận duyệt đơn</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <p>Bạn có chắc chắn muốn duyệt đơn nghỉ phép của <strong>@item.Employee?.FullName</strong>?</p>
                                                        <div class="mb-3">
                                                            <label for="note-@item.Id" class="form-label">Ghi chú (Tùy chọn)</label>
                                                            <textarea class="form-control" name="note" id="note-@item.Id" rows="2"></textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                        <button type="submit" class="btn btn-success">Duyệt</button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>

                                    <!-- Reject Modal -->
                                    <div class="modal fade" id="rejectModal-@item.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <form asp-action="ProcessRequest" method="post">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="status" value="@QLNS.FullNet.Data.Entities.LeaveRequestStatus.Rejected" />
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Xác nhận từ chối đơn</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <p>Bạn có chắc chắn muốn từ chối đơn nghỉ phép của <strong>@item.Employee?.FullName</strong>?</p>
                                                        <div class="mb-3">
                                                            <label for="note-reject-@item.Id" class="form-label">Lý do từ chối</label>
                                                            <textarea class="form-control" name="note" id="note-reject-@item.Id" rows="2" required></textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                        <button type="submit" class="btn btn-danger">Từ chối</button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
