@model IEnumerable<QLNS.FullNet.Data.Entities.Timekeeping>
@using QLNS.FullNet.Data.Entities

@{
    ViewData["Title"] = "Chấm công của tôi";
    var todayRecord = ViewBag.TodayRecord as Timekeeping;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">Chấm công của tôi</h1>
</div>


@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}


@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Check-in / Check-out actions -->
<div class="card shadow mb-4 border-left-primary">
    <div class="card-body">
        <h5 class="card-title">Hôm nay: @DateTime.Today.ToString("dd/MM/yyyy")</h5>
        
        <div class="mt-3 d-flex gap-3">
            @if (todayRecord == null || todayRecord.CheckInTime == null)
            {
                <form asp-action="CheckIn" method="post">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-sign-in-alt"></i> Check-in
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-secondary btn-lg" disabled>
                    <i class="fas fa-check"></i> Đã Check-in (@todayRecord.CheckInTime?.ToString("hh\\:mm"))
                </button>
            }

            @if (todayRecord != null && todayRecord.CheckInTime != null && todayRecord.CheckOutTime == null)
            {
                <form asp-action="CheckOut" method="post">
                    <button type="submit" class="btn btn-warning btn-lg">
                        <i class="fas fa-sign-out-alt"></i> Check-out
                    </button>
                </form>
            }
            else if (todayRecord != null && todayRecord.CheckOutTime != null)
            {
                <button class="btn btn-secondary btn-lg" disabled>
                    <i class="fas fa-check-double"></i> Đã Check-out (@todayRecord.CheckOutTime?.ToString("hh\\:mm"))
                </button>
            }
        </div>
    </div>
</div>

<!-- History -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Lịch sử chấm công</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>Ngày</th>
                        <th>Check-in</th>
                        <th>Check-out</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Date.ToString("dd/MM/yyyy")</td>
                            <td>@(item.CheckInTime?.ToString("hh\\:mm") ?? "-")</td>
                            <td>@(item.CheckOutTime?.ToString("hh\\:mm") ?? "-")</td>
                            <td>@item.Note</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

