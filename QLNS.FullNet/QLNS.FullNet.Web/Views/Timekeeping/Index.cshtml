@model IEnumerable<QLNS.FullNet.Data.Entities.Timekeeping>

@{
    ViewData["Title"] = "Dữ liệu chấm công";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">Dữ liệu chấm công</h1>
    <a asp-action="ManualEntry" class="btn btn-primary">
        <i class="fas fa-plus fa-sm text-white-50"></i> Nhập công thủ công
    </a>
</div>


@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>Nhân viên</th>
                        <th>Ngày</th>
                        <th>Check-in</th>
                        <th>Check-out</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Employee?.FullName</td>
                            <td>@item.Date.ToString("dd/MM/yyyy")</td>
                            <td>@(item.CheckInTime?.ToString("hh\\:mm") ?? "-")</td>
                            <td>@(item.CheckOutTime?.ToString("hh\\:mm") ?? "-")</td>
                            <td>@item.Note</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

