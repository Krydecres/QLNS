@model IEnumerable<QLNS.FullNet.Data.Entities.Timekeeping>

@{
    ViewData["Title"] = "Quản lý Chấm công";
}

<div class="dashboard">
    <div class="dashboard-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="dashboard-title">Danh sách Chấm công</h1>
            <p class="dashboard-subtitle">Quản lý lịch sử và trạng thái chấm công của nhân viên</p>
        </div>
        <div class="dashboard-actions d-flex gap-2 align-items-center">
            <!-- Form chọn nhân viên để chấm công (dành cho Admin) -->
            <form asp-action="CheckIn" method="post" class="m-0 d-flex gap-2">
                <select name="employeeId" class="form-select" required style="min-width: 200px;">
                    <option value="">-- Chọn nhân viên --</option>
                    @if (ViewBag.Employees != null)
                    {
                        foreach (var emp in ViewBag.Employees)
                        {
                            <option value="@emp.Id">@emp.FullName (@emp.Email)</option>
                        }
                    }
                </select>
                <button type="submit" class="btn btn-primary text-nowrap">
                    <i class="bi bi-check2-circle"></i> Chấm công
                </button>
            </form>
            <!-- Nút Xuất Excel -->
            <a asp-controller="Timekeeping" asp-action="ExportExcel" asp-route-startDate="@ViewBag.StartDate" asp-route-endDate="@ViewBag.EndDate" class="btn btn-success">
                <i class="bi bi-file-earmark-excel"></i> Xuất dữ liệu ra Excel
            </a>
        </div>
    </div>

    <!-- Hiển thị thông báo nếu có -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3 mb-0" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3 mb-0" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Thanh công cụ Lọc dữ liệu -->
    <div class="d-flex justify-content-between align-items-center bg-white p-3 rounded shadow-sm mt-3 border">
        <form asp-action="Index" method="get" class="m-0 d-flex flex-wrap gap-2 align-items-center">
            <span class="fw-semibold text-muted me-2"><i class="bi bi-funnel"></i> Lọc thời gian:</span>
            
            <div class="input-group" style="width: auto;">
                <span class="input-group-text bg-light">Từ</span>
                <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate">
            </div>
            
            <div class="input-group" style="width: auto;">
                <span class="input-group-text bg-light">Đến</span>
                <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate">
            </div>

            <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Áp dụng</button>
            
            @if (ViewBag.StartDate != null || ViewBag.EndDate != null)
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
            }
        </form>
    </div>

    <div class="chart-card mt-3">
        <table class="data-table table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th width="10%">ID</th>
                    <th>Tên Nhân Viên</th>
                    <th>Ngày Chấm Công</th>
                    <th width="20%" class="text-center">Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="fw-bold text-primary">@(item.Employee?.FullName ?? "N/A")</td>
                            <td>@item.Date.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                @if(item.Status == "Có mặt") {
                                    <span class="badge bg-success px-3 py-2">@item.Status</span>
                                } else {
                                    <span class="badge bg-danger px-3 py-2">@item.Status</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu chấm công.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>