@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    string IsActive(string controller, string action = "Index")
        => (currentController == controller && currentAction == action) ? "active" : "";
}

<nav class="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">
            <i class="bi bi-people-fill"></i>
        </div>
        <span class="sidebar-title">QLNS</span>
    </div>

    <div class="sidebar-section-label">TỔNG QUAN</div>
    <ul class="sidebar-nav">
        <li>
            <a href="@Url.Action("Index", "Home")" class="sidebar-link @IsActive("Home")">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Dashboard</span>
            </a>
        </li>
    </ul>

    <div class="sidebar-section-label">NHÂN SỰ</div>
    <ul class="sidebar-nav">
        <li>
            <a href="@Url.Action("Index", "NhanVien")" class="sidebar-link @IsActive("NhanVien")">
                <i class="bi bi-person-badge"></i>
                <span>Quản lý nhân viên</span>
            </a>
        </li>
        <li>
            <a href="@Url.Action("Index", "PhongBan")" class="sidebar-link @IsActive("PhongBan")">
                <i class="bi bi-diagram-3"></i>
                <span>Phòng ban</span>
            </a>
        </li>
        <li>
            <a href="@Url.Action("Index", "ChucVu")" class="sidebar-link @IsActive("ChucVu")">
                <i class="bi bi-award"></i>
                <span>Chức vụ</span>
            </a>
        </li>
        <li>
            <a href="@Url.Action("Index", "HopDong")" class="sidebar-link @IsActive("HopDong")">
                <i class="bi bi-file-earmark-text"></i>
                <span>Hợp đồng</span>
            </a>
        </li>
    </ul>

    <div class="sidebar-section-label">CHẤM CÔNG</div>
    <ul class="sidebar-nav">
        <li>
            <a href="@Url.Action("Index", "ChamCong")" class="sidebar-link @IsActive("ChamCong")">
                <i class="bi bi-clock-history"></i>
                <span>Chấm công theo ca</span>
            </a>
        </li>
        <li>
            <a href="@Url.Action("Index", "Ca")" class="sidebar-link @IsActive("Ca")">
                <i class="bi bi-calendar2-week"></i>
                <span>Quản lý ca làm</span>
            </a>
        </li>
        <li>
            <a href="@Url.Action("Index", "NghiPhep")" class="sidebar-link @IsActive("NghiPhep")">
                <i class="bi bi-calendar-x"></i>
                <span>Nghỉ phép</span>
            </a>
        </li>
        <li>
            <a href="@Url.Action("Index", "TangCa")" class="sidebar-link @IsActive("TangCa")">
                <i class="bi bi-hourglass-split"></i>
                <span>Tăng ca</span>
            </a>
        </li>
    </ul>

    <div class="sidebar-section-label">LƯƠNG & BÁO CÁO</div>
    <ul class="sidebar-nav">
        <li>
            <a href="@Url.Action("Index", "TinhLuong")" class="sidebar-link @IsActive("TinhLuong")">
                <i class="bi bi-cash-coin"></i>
                <span>Tính lương</span>
            </a>
        </li>
        <li>
            <a href="@Url.Action("Index", "BangLuong")" class="sidebar-link @IsActive("BangLuong")">
                <i class="bi bi-table"></i>
                <span>Bảng lương</span>
            </a>
        </li>
        <li>
            <a href="@Url.Action("Index", "BaoCao")" class="sidebar-link @IsActive("BaoCao")">
                <i class="bi bi-bar-chart-line"></i>
                <span>Báo cáo tháng</span>
            </a>
        </li>
    </ul>

    <div class="sidebar-section-label">HỆ THỐNG</div>
    <ul class="sidebar-nav">
        <li>
            <a href="@Url.Action("Index", "CaiDat")" class="sidebar-link @IsActive("CaiDat")">
                <i class="bi bi-gear"></i>
                <span>Cài đặt</span>
            </a>
        </li>
    </ul>

    <div class="sidebar-footer">
        <div class="today-card">
            <div class="today-label">Hôm nay — @DateTime.Now.ToString("dd/MM/yyyy")</div>
            <div class="today-schedule">Chấm công đang mở</div>
            <div class="today-sub">Ca sáng: 07:30 – 11:30</div>
        </div>
    </div>
</nav>