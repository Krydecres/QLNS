@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    string IsActive(string controller, string action = "Index")
        => (currentController == controller && currentAction == action) ? "active" : "";
}

<nav class="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">
            <i class="bi bi-people-fill"></i>
        </div>
        <span class="sidebar-title">QLNS</span>
    </div>

    @if (!User.Identity.IsAuthenticated)
    {
        <div class="sidebar-section-label">TÀI KHOẢN</div>
        <ul class="sidebar-nav">
            <li>
                <a href="@Url.Action("Login", "Auth")" class="sidebar-link @IsActive("Auth", "Login")">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Đăng nhập</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Register", "Auth")" class="sidebar-link @IsActive("Auth", "Register")">
                    <i class="bi bi-person-plus"></i>
                    <span>Đăng ký</span>
                </a>
            </li>
        </ul>
    }
    else if (User.IsInRole("Admin"))
    {
        <div class="sidebar-section-label">TỔNG QUAN</div>
        <ul class="sidebar-nav">
            <li>
                <a href="@Url.Action("Index", "Home")" class="sidebar-link @IsActive("Home")">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Dashboard</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-section-label">QUẢN TRỊ NHÂN SỰ</div>
        <ul class="sidebar-nav">
            <li>
                 <a href="@Url.Action("Index", "User")" class="sidebar-link @IsActive("User")">
                    <i class="bi bi-person-gear"></i>
                    <span>Người dùng & phân quyền</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Employee")" class="sidebar-link @IsActive("Employee")">
                    <i class="bi bi-person-badge"></i>
                    <span>Quản lý nhân viên</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Department")" class="sidebar-link @IsActive("Department")">
                    <i class="bi bi-diagram-3"></i>
                    <span>Phòng ban</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Position")" class="sidebar-link @IsActive("Position")">
                    <i class="bi bi-award"></i>
                    <span>Chức vụ</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("PendingProfileUpdates", "Employee")" class="sidebar-link @IsActive("Employee", "PendingProfileUpdates")">
                    <i class="bi bi-person-lines-fill"></i>
                    <span>Duyệt cập nhật hồ sơ</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-section-label">CHẤM CÔNG & CA LÀM</div>
        <ul class="sidebar-nav">
            <li>
                <a href="@Url.Action("Index", "Timekeeping")" class="sidebar-link @IsActive("Timekeeping")">
                    <i class="bi bi-clock-history"></i>
                    <span>Dữ liệu chấm công</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Shift")" class="sidebar-link @IsActive("Shift")">
                    <i class="bi bi-calendar2-week"></i>
                    <span>Quản lý ca làm</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Approval", "LeaveRequest")" class="sidebar-link @IsActive("LeaveRequest", "Approval")">
                    <i class="bi bi-calendar-check"></i>
                    <span>Duyệt nghỉ phép</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Holiday")" class="sidebar-link @IsActive("Holiday")">
                    <i class="bi bi-calendar-event"></i>
                    <span>Ngày nghỉ lễ</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-section-label">LƯƠNG THƯỞNG</div>
        <ul class="sidebar-nav">
            <li>
                <a href="@Url.Action("Index", "Salaries")" class="sidebar-link @IsActive("Salaries")">
                    <i class="bi bi-table"></i>
                    <span>Bảng lương</span>
                </a>
            </li>
        </ul>
    }
    else if (User.IsInRole("Employee"))
    {
        <div class="sidebar-section-label">CÁ NHÂN</div>
        <ul class="sidebar-nav">
            <li>
                <a href="@Url.Action("MyProfile", "Employee")" class="sidebar-link @IsActive("Employee", "MyProfile")">
                    <i class="bi bi-person"></i>
                    <span>Thông tin cá nhân</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("MyDepartment", "Employee")" class="sidebar-link @IsActive("Employee", "MyDepartment")">
                    <i class="bi bi-people-fill"></i>
                    <span>Phòng ban của tôi</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("MyAttendance", "Timekeeping")" class="sidebar-link @IsActive("Timekeeping", "MyAttendance")">
                    <i class="bi bi-clock"></i>
                    <span>Chấm công của tôi</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("MyLeaves", "LeaveRequest")" class="sidebar-link @IsActive("LeaveRequest", "MyLeaves")">
                    <i class="bi bi-calendar-minus"></i>
                    <span>Nghỉ phép của tôi</span>
                </a>
            </li>
            <li>
                <a href="@Url.Action("MyDaysOff", "LeaveRequest")" class="sidebar-link @IsActive("LeaveRequest", "MyDaysOff")">
                    <i class="bi bi-calendar2-heart"></i>
                    <span>Ngày nghỉ của tôi</span>
                </a>
            </li>
        </ul>
    }

    <div class="sidebar-footer mt-auto">
        @if (User.Identity.IsAuthenticated)
        {
            <form method="post" action="@Url.Action("Logout", "Auth")" class="m-0 p-3">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger w-100 d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-box-arrow-right"></i>
                    Đăng xuất
                </button>
            </form>
        }
        else
        {
            <div class="today-card">
                <div class="today-label">Hôm nay — @DateTime.Now.ToString("dd/MM/yyyy")</div>
                <div class="today-schedule">Vui lòng đăng nhập</div>
                <div class="today-sub">để sử dụng hệ thống</div>
            </div>
        }
    </div>
</nav>