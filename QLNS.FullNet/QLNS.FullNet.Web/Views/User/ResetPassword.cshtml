@model QLNS.FullNet.Data.Entities.AppUser

@{
    ViewData["Title"] = "Reset mật khẩu";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white">
            <h4 class="mb-0">Reset mật khẩu</h4>
        </div>

        <div class="card-body">
            <div class="alert alert-warning">
                Bạn đang reset mật khẩu cho tài khoản <strong>@Model.Username</strong>.
            </div>

            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="id" value="@Model.Id" />

                <div class="mb-3">
                    <label class="form-label">Mật khẩu mới</label>
                    <input type="password"
                           name="newPassword"
                           class="form-control"
                           placeholder="Nhập mật khẩu mới, tối thiểu 6 ký tự" />
                    <span class="text-danger">@Html.ValidationMessage("newPassword")</span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-key"></i> Reset mật khẩu
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>