@model List<QLNS.FullNet.Data.Entities.AppUser>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Quản lý người dùng</h2>
            <p class="text-muted mb-0">Quản trị tài khoản và phân quyền người dùng trong hệ thống.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <form method="get" asp-action="Index" class="row g-2 mb-3">
        <div class="col-md-4">
            <input type="text"
                   name="search"
                   value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Tìm theo tài khoản, họ tên, email, role..." />
        </div>
        <div class="col-md-auto">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i> Tìm kiếm
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Làm mới</a>
        </div>
    </form>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 70px;">ID</th>
                        <th>Tài khoản</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th class="text-end" style="width: 260px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.Id</td>
                                <td>@user.Username</td>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="badge bg-danger">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">Employee</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="EditRole"
                                       asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-shield-lock"></i> Gán quyền
                                    </a>

                                    <a asp-action="ResetPassword"
                                       asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-key"></i> Reset mật khẩu
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Không tìm thấy người dùng nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>