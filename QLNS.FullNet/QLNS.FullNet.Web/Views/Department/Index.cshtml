@model IEnumerable<QLNS.FullNet.Data.Entities.Department>
@{
    ViewData["Title"] = "Quản lý phòng ban";
}

<div class="dashboard">
    <div class="dashboard-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="dashboard-title">Danh sách phòng ban</h1>
            <p class="dashboard-subtitle">Quản lý thông tin cơ cấu phòng ban trong công ty</p>
        </div>
        <div class="dashboard-actions">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Thêm phòng ban
            </a>
        </div>
    </div>

    <div class="chart-card mt-3">
        <table class="data-table table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th width="10%">Mã PB</th>
                    <th>Tên phòng ban</th>
                    <th width="20%" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="fw-bold">
                                <a asp-action="Details" asp-route-id="@item.Id">@item.Name</a>
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Chỉnh sửa"><i class="bi bi-pencil-square"></i> Sửa</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa phòng ban @item.Name?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa"><i class="bi bi-trash"></i> Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">Chưa có dữ liệu phòng ban.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>