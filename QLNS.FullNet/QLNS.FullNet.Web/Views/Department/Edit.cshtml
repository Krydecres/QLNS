@model QLNS.FullNet.Data.Entities.Department
@{
    ViewData["Title"] = "Chỉnh sửa phòng ban";
}

<div class="dashboard">
    <div class="dashboard-header">
        <div>
            <h1 class="dashboard-title">Chỉnh sửa phòng ban</h1>
            <p class="dashboard-subtitle">Cập nhật thông tin phòng ban hiện tại</p>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <div class="chart-card">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên phòng ban..." />
                        <span asp-validation-for="Name" class="text-danger mt-1 d-block"></span>
                    </div>
                    
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check2-circle"></i> Cập nhật</button>
                        <a asp-action="Index" class="btn btn-light border"><i class="bi bi-arrow-left"></i> Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>