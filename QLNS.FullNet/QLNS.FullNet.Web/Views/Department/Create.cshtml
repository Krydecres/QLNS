@model QLNS.FullNet.Data.Entities.Department
@{
    ViewData["Title"] = "Thêm mới phòng ban";
}

<div class="dashboard">
    <div class="dashboard-header">
        <div>
            <h1 class="dashboard-title">Thêm mới phòng ban</h1>
            <p class="dashboard-subtitle">Tạo mới thông tin một phòng ban trên hệ thống</p>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <div class="chart-card">
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <input asp-for="Name" class="form-control" placeholder="Ví dụ: Phòng IT, Phòng Kinh doanh..." />
                        <span asp-validation-for="Name" class="text-danger mt-1 d-block"></span>
                    </div>
                    
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu dữ liệu</button>
                        <a asp-action="Index" class="btn btn-light border"><i class="bi bi-x-circle"></i> Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>